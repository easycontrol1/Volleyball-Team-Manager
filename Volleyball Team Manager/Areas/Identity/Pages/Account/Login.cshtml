@page
@model VolleyballManager.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center align-items-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4>🏐 Вход в системата</h4>
                </div>
                <div class="card-body p-4">
                    <form id="account" method="post" class="text-center">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Имейл адрес</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="form-label">Парола</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        
                        <div class="checkbox mb-3 text-start">
                            <label asp-for="Input.RememberMe" class="form-label">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                Запомни ме
                            </label>
                        </div>
                        
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Влез</button>
                    </form>
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <p>
                        Нямаш акаунт? <a id="forgot-password" asp-page="./Register" class="text-decoration-none fw-bold">Регистрирай се тук</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}