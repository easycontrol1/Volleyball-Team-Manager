@model IEnumerable<VolleyballManager.Data.Models.Player>

@{
    ViewData["Title"] = "Отбор";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">🏐 Състав на отбора</h2>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <i class="bi bi-plus-circle"></i> Нов Играч
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Име</th>
                    <th>Позиция</th>
                    <th>Ръст</th>
                    <th>Отскок</th>
                    <th>Възраст</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-secondary">@item.ShirtNumber</td>
                        <td>
                            <span class="fw-bold">@item.FirstName @item.LastName</span>
                        </td>
                        <td>
                            @switch (item.Position)
                            {
                                case "Setter":
                                    <span class="badge bg-warning text-dark">@item.Position</span>
                                    ; break;
                                case "Libero":

                                    <span class="badge bg-info text-dark">@item.Position</span>
                                    ; break;
                                case "Middle Blocker":

                                    <span class="badge bg-danger">@item.Position</span>
                                    ; break;
                                case "Outside Hitter":

                                    <span class="badge bg-success">@item.Position</span>
                                    ; break;
                                default:

                                    <span class="badge bg-secondary">@item.Position</span>
                                    ; break;
                            }
                        </td>
                        <td>@item.Height см</td>
                        <td>@item.VerticalJump см</td>
                        <td>@item.Age</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редакция</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Детайли</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>