@model VolleyballManager.Data.Models.Match

@{
    ViewData["Title"] = "Нов Мач";
}

<h2 class="text-primary">Добавяне на мач в календара</h2>

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Date" class="form-label">Дата на мача</label>
                            <input asp-for="Date" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IsHomeGame" class="form-label mt-4">Дали сме домакини?</label>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsHomeGame" role="switch">
                                <label class="form-check-label" for="IsHomeGame">
                                    @if (Model != null && Model.IsHomeGame)
                                    {
                                        <span class="text-primary">Да, играме у дома</span>
                                    }
                                    else
                                    {

                                        <span class="text-warning">Не, сме гости</span>
                                    }
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Opponent" class="form-label">Име на противника</label>
                        <input asp-for="Opponent" class="form-control" placeholder="напр. Славия" />
                        <span asp-validation-for="Opponent" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Result" class="form-label">Краен резултат (ако е изигран)</label>
                        <input asp-for="Result" class="form-control" placeholder="напр. 3:1" />
                    </div>

                    <div class="form-group">
                        <input type="submit" value="Запиши мач" class="btn btn-primary w-100" />
                        <a asp-action="Index" class="btn btn-light w-100 mt-2">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>