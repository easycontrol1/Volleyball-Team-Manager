@model VolleyballManager.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Админ Панел";
}

<div class="container mt-4">
    <h1 class="mb-4 text-primary">🔐 Административен Панел</h1>

    <!-- КАРТИ ЗА СТАТИСТИКА -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Играчи</h5>
                    <p class="card-text display-4 fw-bold">@Model.TotalPlayers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Мачове</h5>
                    <p class="card-text display-4 fw-bold">@Model.TotalMatches</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Потребители</h5>
                    <p class="card-text display-4 fw-bold">@Model.TotalUsers</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-dark mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Последен Мач</h5>
                    <p class="card-text fs-5 fw-bold">@Model.LastMatchOpponent</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- КОЛОНА С ДЕЙСТВИЯ -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light fw-bold">Бързи Действия</div>
                <div class="card-body d-grid gap-2">
                    <a asp-controller="Players" asp-action="Create" class="btn btn-outline-primary">➕ Добави Играч</a>
                    <a asp-controller="Matches" asp-action="Create" class="btn btn-outline-success">➕ Добави Мач</a>
                    <hr />
                    <a asp-controller="Players" asp-action="Index" class="btn btn-light">Управление на Играчи</a>
                    <a asp-controller="Matches" asp-action="Index" class="btn btn-light">Управление на Мачове</a>
                    
                    <div class="mt-4">
                        <form asp-action="ResetDatabase" method="post" onsubmit="return confirm('СИГУРЕН ЛИ СИ? Това ще изтрие ВСИЧКИ играчи и мачове!');">
                            <button type="submit" class="btn btn-danger w-100">⚠️ Нулиране на Базата</button>
                        </form>
                        <small class="text-muted">Изтрива само данните за мачове, не потребителите.</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- КОЛОНА С ПОТРЕБИТЕЛИ -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Регистрирани Потребители</h5>
                    <span class="badge bg-light text-dark">@Model.Users.Count()</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Имейл</th>
                                <th>Идентификатор (ID)</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>@user.Email</td>
                                    <td><small class="text-muted">@user.Id</small></td>
                                    <td class="text-end">
                                        @if (user.Email != "admin@vm.bg") // Предпазваме админа от изтриване
                                        {
                                            <form asp-action="DeleteUser" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Изтрий този потребител?');">Изтрий</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Админ</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>